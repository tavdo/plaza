## Nano Banana (NanoBananaAPI.ai) — dev proxy only (see vite.config.ts)
## Copy to .env.local — never commit .env.local
NANO_BANANA_API_KEY=

## Optional override for SPA API base path (defaults to "/api/nanobanana" with Vite proxy in dev).
# VITE_NANO_BANANA_API_BASE=/api/nanobanana

## SPA admin console — VITE_ values are still client-visible; use only as a temporary bridge until server auth.
# VITE_MERGE_ADMIN_OWNER_EMAIL=
# VITE_MERGE_ADMIN_OWNER_PASS=
# VITE_MERGE_ADMIN_MANAGER_EMAIL=
# VITE_MERGE_ADMIN_MANAGER_PASS=
